# 慧惠本地开发服务器 — 环境变量配置
# 复制此文件为 .env，然后填入你的 DeepSeek API Key
# .env 文件已加入 .gitignore，不会被提交到仓库

# DeepSeek API Key（必填）
# 获取地址：https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=sk-your-deepseek-api-key-here

# 本地服务器端口（可选，默认 8080）
# PORT=8080

# Resend API Key（邮件发送服务，用于用户反馈转发）
# 获取地址：https://resend.com/api-keys
# RESEND_API_KEY=re_xxxxxxxxxxxx
