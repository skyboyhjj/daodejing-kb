# 压缩包
*.gz
*.zip
*.tar

# 临时脚本
*.py
_*.py
!scripts/*.py
__pycache__/

# 系统文件
.DS_Store
Thumbs.db
desktop.ini

# 编辑器
.vscode/
.idea/
*.swp
*.swo

# 环境变量（含密钥，不能入库）
.env
.dev.vars

# 依赖
node_modules/

# Cloudflare Wrangler
.wrangler/
wrangler.jsonc
.vercel
.vercel-tmp
nul

# Test artifacts
scripts/test-write.txt
scripts/test-py-write.txt
server_test.log

# 数据备份（不入库）
data/*_backup.json

# 元数据 — 完整版含审计字段不入库，仅脱敏公开版入库
data/family_metadata.json
data/family_metadata_staging.json

# Bug 报告与用户上传附件（不入库）
bugs/

# GA 子模块（不入库）
docs/GA评估资料/GenericAgent/
