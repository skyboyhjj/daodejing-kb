{
    "name": "daodejing-kb",
    "version": "1.0.0",
    "description": "道德经亲子体验营知识库 — 自动化运营工具链",
    "private": true,
    "scripts": {
        "build:index": "node scripts/build-index.js",
        "validate": "node scripts/validate.js",
        "validate:fix": "node scripts/validate.js --fix",
        "validate:docs": "node scripts/validate-docs.js",
        "version": "node scripts/version-manifest.js",
        "report": "node scripts/report.js",
        "pipeline": "node scripts/batch-runner.js",
        "build:public-metadata": "node scripts/build-public-metadata.js",
        "check:metadata": "node scripts/build-public-metadata.js --check",
        "test:metadata": "node scripts/test-metadata.js",
        "test:metadata:verbose": "node scripts/test-metadata.js --verbose",
        "ci": "node scripts/validate.js && node scripts/build-index.js --check && node scripts/build-public-metadata.js --check && node scripts/test-metadata.js"
    },
    "engines": {
        "node": ">=16.0.0"
    }
}